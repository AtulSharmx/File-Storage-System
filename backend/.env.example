# ---- Use ONE of the two setups below ----

# OPTION A: Local MinIO (no AWS account needed, runs on your own laptop)
# S3_ENDPOINT_URL=http://localhost:9000
# AWS_ACCESS_KEY_ID=admin
# AWS_SECRET_ACCESS_KEY=admin12345
# AWS_REGION=us-east-1
# S3_BUCKET_NAME=file-storage-project

# OPTION B: Real AWS S3 (use this later if you get a card sorted)
Comment out the 5 lines above, uncomment these, fill in real values:
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY_ID
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_ACCESS_KEY
AWS_REGION=ap-south-1
S3_BUCKET_NAME=your-bucket-name